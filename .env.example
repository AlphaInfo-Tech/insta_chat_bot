# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL, from Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
# Service-role key (server-side only, bypasses RLS) — from Supabase project settings > API
# NEVER expose this to the client / commit it / log it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Groq ──────────────────────────────────────────────────────────────────
# From https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# Model id used for answering business questions. Alternates on Groq's catalog
# include Qwen and DeepSeek models — swap the id below to switch (check
# https://console.groq.com/docs/models for current ids).
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: cheaper/smaller model for conversation summarization. Defaults to
# GROQ_MODEL if unset.
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile

# ── Meta / Instagram Graph API ───────────────────────────────────────────
# App secret, used to verify X-Hub-Signature-256 on incoming webhooks
META_APP_SECRET=your-meta-app-secret
# Shared secret you choose; must match what you enter in the Meta App
# Dashboard's webhook subscription "Verify Token" field
META_VERIFY_TOKEN=your-chosen-verify-token
# Page access token used to call the Instagram Send API
META_PAGE_ACCESS_TOKEN=your-page-access-token
# Graph API version, bumpable without a code change. Check
# developers.facebook.com/docs/graph-api/changelog for the current version —
# Meta only keeps roughly the last ~2 years of versions live, and calling a
# retired version can surface as a confusing OAuth/token error rather than a
# clear "version deprecated" one.
INSTAGRAM_GRAPH_API_VERSION=v25.0
# Set to "true" to skip the real Instagram Send API call and log the reply
# instead — lets you smoke-test the whole pipeline locally (see
# docs/DEPLOYMENT.md) before you have a real Meta App / Page token. Leave
# unset (or "false") in production.
MOCK_INSTAGRAM=false

# ── Admin knowledge ingestion ────────────────────────────────────────────
# Shared secret required in the x-admin-api-key header on POST /api/admin/knowledge
ADMIN_API_KEY=your-chosen-admin-api-key
# Every ingested page (PDF or TXT) is further split into chunks of this many
# words before embedding — keeps each chunk within the embedding model's
# context window and avoids diluting semantic meaning across a whole page.
KNOWLEDGE_CHUNK_WORDS=50

# ── Rate limiting (Supabase-backed, fixed window) ────────────────────────
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ── Token budgets ─────────────────────────────────────────────────────────
KNOWLEDGE_CONTEXT_MAX_TOKENS=1200
CONVERSATION_HISTORY_MAX_TOKENS=600
ANSWER_MAX_TOKENS=250
SUMMARIZATION_THRESHOLD_MESSAGES=50

# ── Misc ──────────────────────────────────────────────────────────────────
NODE_ENV=development
