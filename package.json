{
  "name": "instagram-ai-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Instagram AI chatbot using RAG over PostgreSQL Full-Text Search (no embeddings, no vector DB), Groq LLM, and Vercel serverless functions.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knowledge:upload": "tsx scripts/upload-knowledge.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "groq-sdk": "^0.7.0",
    "next": "^15.0.3",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.4",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
